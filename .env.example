# Environment Variables Configuration
# This file documents all environment variables needed for the application
# 
# IMPORTANT: 
# - In PRODUCTION: .env file is AUTO-GENERATED by CI/CD (.github/workflows/deploy.yml)
# - In DEVELOPMENT: Copy this to .env.local and fill in actual values

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://flashcards:PASSWORD@postgres:5432/flashcards
DB_PASSWORD=your-database-password-here

# =============================================================================
# NextAuth (Authentication)
# =============================================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Development: http://localhost:8000
# Production: https://conozco.net
NEXTAUTH_URL=http://localhost:8000

# =============================================================================
# Email Service (Resend)
# =============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender email (must be verified domain in Resend)
EMAIL_FROM=noreply@conozco.net

# =============================================================================
# OAuth Providers
# =============================================================================
# Google OAuth - Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# External APIs
# =============================================================================
# DeepL Translation API - Get from: https://www.deepl.com/pro-api
DEEPL_API_KEY=your-deepl-api-key:fx

# =============================================================================
# Application Settings
# =============================================================================
NODE_ENV=development

# Admin registration password (for creating users via admin API)
ADMIN_REGISTRATION_PASSWORD=your-secure-admin-password

# Docker image tag (set automatically by CI/CD)
IMAGE_TAG=sha-latest
