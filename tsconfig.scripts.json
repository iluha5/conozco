{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "outDir": "./",
        "rootDir": "./",
        "noEmit": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": false,
        "sourceMap": false
    },
    "include": [
        "scripts/apply-data-migrations/apply-data-migrations.mts",
        "scripts/generate-word-migration.ts"
    ],
    "exclude": ["node_modules", "scripts/**/*.test.ts", "scripts/cursor/**"]
}
