{
    "extends": ["next/core-web-vitals", "plugin:prettier/recommended"],
    "ignorePatterns": ["**/*.md"],
    "rules": {
        "no-unused-vars": [
            "error",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_",
                "caughtErrorsIgnorePattern": "^_"
            }
        ]
    }
}
