generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SentenceType {
  id                  Int                  @id @default(autoincrement())
  code                String               @unique
  displayName         String
  isNegative          Boolean              @default(false)
  isQuestion          Boolean              @default(false)
  grammaticalExamples GrammaticalExample[]
  wordExamples        WordExample[]

  @@unique([isNegative, isQuestion])
}

model WordStatus {
  id          Int    @id @default(autoincrement())
  code        String @unique
  displayName String
  words       Word[]
}

model UserRole {
  id          Int    @id @default(autoincrement())
  code        String @unique
  displayName String
  users       User[]
}

model PartOfSpeech {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  customTranslations CustomTranslation[]
  wordTranslations   WordTranslation[]
}

model Language {
  id                                     Int                  @id @default(autoincrement())
  code                                   String               @unique
  name                                   String
  apiRequestLogsSourceLanguage           ApiRequestLog[]      @relation("ApiRequestLogSourceLanguage")
  apiRequestLogsTargetLanguage           ApiRequestLog[]      @relation("ApiRequestLogTargetLanguage")
  baseWords                              BaseWord[]
  customTranslationsOriginal             CustomTranslation[]  @relation("CustomTranslationOriginalLanguage")
  customTranslationsTranslation          CustomTranslation[]  @relation("CustomTranslationTranslationLanguage")
  grammaticalExamplesTranslationLanguage GrammaticalExample[] @relation("GrammaticalExampleTranslationLanguage")
  pronouns                               Pronoun[]
  tenses                                 Tense[]
  userInterfaceLanguages                 User[]               @relation("UserInterfaceLanguage")
  userLearnLanguages                     User[]               @relation("UserLearnLanguage")
  userOwnLanguages                       User[]               @relation("UserOwnLanguage")
  words                                  Word[]
  wordExamplesTranslationLanguage        WordExample[]        @relation("WordExampleTranslationLanguage")
  wordGroups                             WordGroup[]
  wordTranslations                       WordTranslation[]

  @@index([code])
}

model User {
  id                  Int                 @id @default(autoincrement())
  email               String              @unique
  password            String
  name                String?
  roleId              Int                 @default(1)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  interfaceLanguageId Int?
  learnLanguageId     Int?
  ownLanguageId       Int?
  hasConfigured       Boolean             @default(false)
  accounts            Account[]
  apiRequestLogs      ApiRequestLog[]
  customTranslations  CustomTranslation[]
  sessions            Session[]
  cookieConsent       UserCookieConsent?
  interfaceLanguage   Language?           @relation("UserInterfaceLanguage", fields: [interfaceLanguageId], references: [id])
  learnLanguage       Language?           @relation("UserLearnLanguage", fields: [learnLanguageId], references: [id])
  ownLanguage         Language?           @relation("UserOwnLanguage", fields: [ownLanguageId], references: [id])
  role                UserRole            @relation(fields: [roleId], references: [id])
  activeWordGroups    UserWordGroup[]
  words               Word[]
  createdWordGroups   WordGroup[]         @relation("CreatedWordGroups")
  sharedWordGroups    WordGroupAccess[]   @relation("SharedWordGroups")

  @@index([email])
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WordSource {
  id                  Int                  @id @default(autoincrement())
  code                String               @unique
  displayName         String
  apiRequestLogs      ApiRequestLog[]
  baseWords           BaseWord[]
  grammaticalExamples GrammaticalExample[]
  wordExamples        WordExample[]
}

model BaseWord {
  id                  Int                   @id @default(autoincrement())
  word                String
  languageId          Int
  sourceId            Int
  language            Language              @relation(fields: [languageId], references: [id])
  source              WordSource            @relation(fields: [sourceId], references: [id])
  wordGroups          BaseWordOnWordGroup[]
  grammaticalExamples GrammaticalExample[]
  userWords           Word[]
  examples            WordExample[]
  translations        WordTranslation[]

  @@unique([word, languageId])
  @@index([languageId])
  @@index([sourceId])
}

model WordGroup {
  id              Int                   @id @default(autoincrement())
  name            String                @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdByUserId Int
  visibility      WordGroupVisibility   @default(PRIVATE)
  isApproved      Boolean               @default(false)
  languageId      Int
  description     String?
  baseWords       BaseWordOnWordGroup[]
  activeUsers     UserWordGroup[]
  createdBy       User                  @relation("CreatedWordGroups", fields: [createdByUserId], references: [id], onDelete: Cascade)
  language        Language              @relation(fields: [languageId], references: [id])
  sharedWith      WordGroupAccess[]

  @@index([name])
  @@index([createdByUserId])
  @@index([languageId])
  @@index([visibility])
  @@index([isApproved])
  @@index([visibility, isApproved])
}

model WordGroupAccess {
  id          Int       @id @default(autoincrement())
  wordGroupId Int
  userId      Int
  grantedAt   DateTime  @default(now())
  user        User      @relation("SharedWordGroups", fields: [userId], references: [id], onDelete: Cascade)
  wordGroup   WordGroup @relation(fields: [wordGroupId], references: [id], onDelete: Cascade)

  @@unique([wordGroupId, userId])
  @@index([wordGroupId])
  @@index([userId])
}

model UserWordGroup {
  id          Int       @id @default(autoincrement())
  userId      Int
  wordGroupId Int
  activatedAt DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordGroup   WordGroup @relation(fields: [wordGroupId], references: [id], onDelete: Cascade)

  @@unique([userId, wordGroupId])
  @@index([userId])
  @@index([wordGroupId])
}

model BaseWordOnWordGroup {
  baseWordId  Int
  wordGroupId Int
  assignedAt  DateTime  @default(now())
  baseWord    BaseWord  @relation(fields: [baseWordId], references: [id], onDelete: Cascade)
  wordGroup   WordGroup @relation(fields: [wordGroupId], references: [id], onDelete: Cascade)

  @@id([baseWordId, wordGroupId])
  @@index([baseWordId])
  @@index([wordGroupId])
}

model WordImage {
  id               Int               @id @default(autoincrement())
  url              String
  alt              String?
  source           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  wordTranslations WordTranslation[]

  @@index([url])
}

model WordTranslation {
  id             Int           @id @default(autoincrement())
  baseWordId     Int
  languageId     Int
  translation    String
  priority       Int           @default(1)
  imageId        Int?
  partOfSpeechId Int?
  selectedByWord Word[]        @relation("SelectedTranslation")
  baseWord       BaseWord      @relation(fields: [baseWordId], references: [id], onDelete: Cascade)
  image          WordImage?    @relation(fields: [imageId], references: [id])
  language       Language      @relation(fields: [languageId], references: [id])
  partOfSpeech   PartOfSpeech? @relation(fields: [partOfSpeechId], references: [id])

  @@unique([baseWordId, languageId, priority])
  @@index([baseWordId])
  @@index([languageId])
  @@index([imageId])
  @@index([partOfSpeechId])
}

model Pronoun {
  id                  Int                  @id @default(autoincrement())
  pronoun             String
  languageId          Int
  grammaticalExamples GrammaticalExample[]
  language            Language             @relation(fields: [languageId], references: [id])
  wordExamples        WordExample[]

  @@unique([pronoun, languageId])
  @@index([languageId])
}

model WordExample {
  id                    Int          @id @default(autoincrement())
  baseWordId            Int
  pronounId             Int
  example               String
  translation           String
  sentenceTypeId        Int
  sourceId              Int
  translationLanguageId Int
  baseWord              BaseWord     @relation(fields: [baseWordId], references: [id], onDelete: Cascade)
  pronoun               Pronoun      @relation(fields: [pronounId], references: [id])
  sentenceType          SentenceType @relation(fields: [sentenceTypeId], references: [id])
  source                WordSource   @relation(fields: [sourceId], references: [id])
  translationLanguage   Language     @relation("WordExampleTranslationLanguage", fields: [translationLanguageId], references: [id])

  @@index([baseWordId])
  @@index([sentenceTypeId])
  @@index([sourceId])
  @@index([translationLanguageId])
}

model Tense {
  id                  Int                  @id @default(autoincrement())
  name                String
  languageId          Int
  grammaticalExamples GrammaticalExample[]
  language            Language             @relation(fields: [languageId], references: [id])

  @@unique([name, languageId])
  @@index([languageId])
}

model GrammaticalExample {
  id                    Int          @id @default(autoincrement())
  baseWordId            Int
  tenseId               Int
  pronounId             Int
  example               String
  translation           String
  sentenceTypeId        Int
  sourceId              Int
  translationLanguageId Int
  baseWord              BaseWord     @relation(fields: [baseWordId], references: [id], onDelete: Cascade)
  pronoun               Pronoun      @relation(fields: [pronounId], references: [id])
  sentenceType          SentenceType @relation(fields: [sentenceTypeId], references: [id])
  source                WordSource   @relation(fields: [sourceId], references: [id])
  tense                 Tense        @relation(fields: [tenseId], references: [id])
  translationLanguage   Language     @relation("GrammaticalExampleTranslationLanguage", fields: [translationLanguageId], references: [id])

  @@index([baseWordId, tenseId])
  @@index([tenseId])
  @@index([sentenceTypeId])
  @@index([sourceId])
  @@index([translationLanguageId])
}

model Word {
  id                    Int                 @id @default(autoincrement())
  userId                Int
  baseWordId            Int?
  customWord            String?
  languageId            Int
  statusId              Int                 @default(1)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  selectedTranslationId Int?
  customTranslations    CustomTranslation[]
  trainingSessions      TrainingSession[]
  baseWord              BaseWord?           @relation(fields: [baseWordId], references: [id])
  language              Language            @relation(fields: [languageId], references: [id])
  selectedTranslation   WordTranslation?    @relation("SelectedTranslation", fields: [selectedTranslationId], references: [id])
  status                WordStatus          @relation(fields: [statusId], references: [id])
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, baseWordId])
  @@unique([userId, customWord, languageId])
  @@index([userId, languageId, statusId])
  @@index([languageId])
  @@index([selectedTranslationId])
}

model CustomTranslation {
  id                    Int           @id @default(autoincrement())
  wordId                Int
  userId                Int
  partOfSpeechId        Int?
  originalLanguageId    Int
  translationLanguageId Int
  translation           String
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  originalLanguage      Language      @relation("CustomTranslationOriginalLanguage", fields: [originalLanguageId], references: [id])
  partOfSpeech          PartOfSpeech? @relation(fields: [partOfSpeechId], references: [id])
  translationLanguage   Language      @relation("CustomTranslationTranslationLanguage", fields: [translationLanguageId], references: [id])
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  word                  Word          @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, userId])
  @@index([wordId])
  @@index([userId])
  @@index([originalLanguageId])
  @@index([translationLanguageId])
}

model TrainingSession {
  id        Int      @id @default(autoincrement())
  wordId    Int
  stage     Int
  isCorrect Boolean
  createdAt DateTime @default(now())
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId, stage])
}

model TrainingLog {
  id               Int      @id @default(autoincrement())
  userId           Int
  sessionId        String   @unique
  selectedLanguage String
  totalWords       Int
  completedWords   Int
  totalAttempts    Int
  correctAttempts  Int
  accuracy         Float
  duration         Int
  enabledStages    String
  stagesProgress   String
  startedAt        DateTime
  completedAt      DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model ApiRequestLog {
  id               Int        @id @default(autoincrement())
  userId           Int?
  requestType      String
  requestData      String
  responseData     String?
  statusCode       Int?
  errorMessage     String?
  duration         Int?
  createdAt        DateTime   @default(now())
  sourceId         Int
  sourceLanguageId Int?
  targetLanguageId Int?
  source           WordSource @relation(fields: [sourceId], references: [id])
  sourceLanguage   Language?  @relation("ApiRequestLogSourceLanguage", fields: [sourceLanguageId], references: [id])
  targetLanguage   Language?  @relation("ApiRequestLogTargetLanguage", fields: [targetLanguageId], references: [id])
  user             User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sourceId, createdAt])
  @@index([sourceLanguageId])
  @@index([targetLanguageId])
  @@index([createdAt])
}

model UserCookieConsent {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  version     String   // Cookie policy version (e.g., "1.0")
  given       Boolean  @default(false) // Whether consent was given
  givenAt     DateTime? // Consent date and time
  withdrawnAt DateTime? // Withdrawal date and time
  preferences Json     // Detailed preferences (necessary, functional, analytics, marketing)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([version])
  @@index([given])
}

model DataMigration {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  appliedAt  DateTime  @default(now())
  appliedBy  String?
  gitSha     String?
  checksum   String
  durationMs Int?
  status     String    @default("SUCCESS")

  @@index([name])
  @@index([appliedAt])
}

enum WordGroupVisibility {
  PUBLIC
  PRIVATE
  SHARED
}
