// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Статус слова
enum WordStatus {
  NOT_LEARNED
  LEARNED
}

// Роль пользователя
enum UserRole {
  USER
  ADMIN
}

// Справочник языков
model Language {
  id    String @id @default(uuid())
  code  String @unique // например: 'en', 'es', 'ru'
  name  String         // например: 'English', 'Spanish', 'Russian'
  
  words             Word[]
  translationCaches TranslationCache[]
  
  @@index([code])
}

// Пользователь
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String    // hashed password
  name          String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  words         Word[]
  accounts      Account[]
  sessions      Session[]
  
  @@index([email])
}

// NextAuth Account
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth Session
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// Таблица слов для изучения
model Word {
  id            String      @id @default(uuid())
  userId        String      // Связь с пользователем
  foreignWord   String      // Слово на иностранном языке
  translation   String      // Основной перевод на русском
  languageId    String      // ID языка слова
  status        WordStatus  @default(NOT_LEARNED)
  examples      String[]    @default([]) // Примеры использования
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Связи
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  language         Language            @relation(fields: [languageId], references: [id], onDelete: Restrict)
  trainingSessions TrainingSession[]

  @@unique([foreignWord, languageId, userId])
  @@index([userId, languageId, status])
  @@index([languageId])
}

// Кеш переводов для минимизации запросов к внешнему API
model TranslationCache {
  id                 String   @id @default(uuid())
  sourceText         String   // Исходное слово
  sourceLanguageId   String   // ID языка источника
  translations       Json     // JSON массив с вариантами переводов и примерами
  createdAt          DateTime @default(now())
  
  // Связи
  sourceLanguage Language @relation(fields: [sourceLanguageId], references: [id], onDelete: Restrict)
  
  @@unique([sourceText, sourceLanguageId])
  @@index([sourceText, sourceLanguageId])
  @@index([sourceLanguageId])
}

// Сессии тренировок для отслеживания прогресса
model TrainingSession {
  id          String   @id @default(uuid())
  wordId      String
  stage       Int      // Этап тренировки (1-4)
  isCorrect   Boolean  // Правильный ли был ответ
  createdAt   DateTime @default(now())
  
  word        Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  
  @@index([wordId, stage])
}

